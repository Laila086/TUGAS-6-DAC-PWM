; PlatformIO - PWM Motor Control
[env:esp32dev]
platform = espressif32
board = esp32dev
framework = arduino

; Serial Monitor Configuration
monitor_speed = 115200
monitor_dtr = 0
monitor_rts = 0

; Upload Configuration (USB-to-Serial)
upload_port = COM4
upload_protocol = esptool
upload_speed = 460800
upload_resetmethod = dtr

; Build Configuration
build_type = release
